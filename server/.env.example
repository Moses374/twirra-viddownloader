# Copy this file to .env and fill in real values. NEVER commit .env.

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace_with_a_random_64_char_hex_string

# JWT algorithm
JWT_ALGORITHM=HS256

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=90

# The single app user's login credentials (this is a private single-user service)
# Generate the hash with: python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('your-password'))"
APP_USERNAME=replace_with_username
APP_PASSWORD_HASH=replace_with_bcrypt_hash

# Directory where temporary downloaded videos are stored before being served & deleted
DOWNLOAD_DIR=/tmp/twirra_downloads

# Comma-separated list of allowed CORS origins (your app's origin, or * during dev only)
CORS_ORIGINS=*

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=10
